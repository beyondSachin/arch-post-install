{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "small",
        "padding": {
            "top": 1,
            "left": 2
        }
    },
    "display": {
        "separator": " ➜  ",
        "color": {
            "keys": "blue",
            "output": "white"
        },
        "key": {
            "width": 15
        },
        "bar": {
            "char": {
                "elapsed": "█",
                "total": "░"
            },
            "width": 18
        },
        "percent": {
            "type": 2 // 1: bar, 2: percent, 3: bar + percent
        }
    },
    "modules": [
        "title",
        {
            "type": "separator",
            "string": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        },
        {
            "type": "os",
            "key": "󰣇 OS",
            "keyColor": "blue"
        },
        {
            "type": "kernel",
            "key": "󰒋 Kernel",
            "keyColor": "blue"
        },
        {
            "type": "uptime",
            "key": "󰔚 Uptime",
            "keyColor": "blue"
        },
        {
            "type": "packages",
            "key": "󰏖 Packages",
            "keyColor": "blue"
        },
        "break",
        {
            "type": "cpu",
            "key": "󰻠 CPU",
            "keyColor": "magenta"
        },
        {
            "type": "gpu",
            "key": "󰢮 GPU",
            "keyColor": "magenta"
        },
        {
            "type": "memory",
            "key": "󰍛 Memory",
            "keyColor": "magenta"
        },
        {
            "type": "disk",
            "key": "󰋊 Disk",
            "keyColor": "magenta"
        },
        "break",
        {
            "type": "wm",
            "key": "󱂬 WM",
            "keyColor": "yellow"
        },
        {
            "type": "terminal",
            "key": "󰆍 Terminal",
            "keyColor": "yellow"
        },
        {
            "type": "shell",
            "key": "󰞷 Shell",
            "keyColor": "yellow"
        },
        {
            "type": "display",
            "key": "󰍹 Resolution",
            "keyColor": "yellow"
        },
        "break",
        {
            "type": "colors",
            "symbol": "circle"
        }
    ]
}
