/**
 * Floating Quick Menu — Rofi Theme
 * Compact, centered floating panel with icon-style items
 * Author: Sachin
 */

@import "/home/sachin/.config/rofi/colors.rasi"

* {
    background-color: transparent;
    text-color:       @foreground;
    border-color:     transparent;
    spacing:          0;
    padding:          0;
    margin:           0;
}

configuration {
    show-icons:       false;
    hover-select:     true;
    me-select-entry:  "";
    me-accept-entry:  "MousePrimary";
    kb-row-up:        "Up,Control+k,Shift+Tab,Control+p";
    kb-row-down:      "Down,Control+j,Control+n";
    kb-accept-entry:  "Control+m,Return,KP_Enter";
    fixed-num-lines:  true;
}

window {
    width:            380px;
    border:           2px solid;
    border-radius:    20px;
    border-color:     @border;
    padding:          0;
    background-color: @background;
    location:         center;
    anchor:           center;
    x-offset:         0;
    y-offset:         0;
}

mainbox {
    padding:          24px;
    spacing:          16px;
    background-color: transparent;
    children:         [ "message", "listview" ];
}

message {
    padding:          12px 16px;
    border-radius:    14px;
    background-color: @background-alt;
}

textbox {
    background-color: transparent;
    text-color:       @accent;
    font:             "JetBrainsMono Nerd Font Bold 13";
    horizontal-align: 0.5;
}

listview {
    columns:          1;
    lines:            5;
    spacing:          8px;
    padding:          0;
    fixed-height:     false;
    fixed-columns:    true;
    background-color: transparent;
    border:           0;
    scrollbar:        false;
    cycle:            true;
    dynamic:          true;
}

element {
    orientation:      horizontal;
    padding:          14px 18px;
    spacing:          14px;
    border-radius:    14px;
    background-color: @background-alt;
    cursor:           pointer;
}

element normal.normal {
    background-color: @background-alt;
    text-color:       @foreground;
}

element selected.normal {
    background-color: @selected;
    text-color:       @background;
}

element-icon {
    size:             0px;
}

element-text {
    background-color: transparent;
    text-color:       inherit;
    font:             "JetBrainsMono Nerd Font 13";
    vertical-align:   0.5;
    horizontal-align: 0.0;
}

