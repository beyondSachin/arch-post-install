{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "palette": {
    "base": "#1e1e2e",
    "mantle": "#181825",
    "crust": "#11111b",
    "surface0": "#313244",
    "surface1": "#45475a",
    "surface2": "#585b70",
    "text": "#cdd6f4",
    "subtext0": "#a6adc8",
    "subtext1": "#bac2de",
    "blue": "#89b4fa",
    "lavender": "#b4befe",
    "sapphire": "#74c7ec",
    "sky": "#89dceb",
    "teal": "#94e2d5",
    "green": "#a6e3a1",
    "yellow": "#f9e2af",
    "peach": "#fab387",
    "maroon": "#eba0ac",
    "red": "#f38ba8",
    "mauve": "#cba6f7",
    "pink": "#f5c2e7",
    "flamingo": "#f2cdcd",
    "rosewater": "#f5e0dc"
  },
  "blocks": [
    {
      "alignment": "left",
      "type": "prompt",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "background": "p:blue",
          "foreground": "p:crust",
          "template": "{{ if .WSL }}WSL ({{ .OS }}){{ else }}{{ .Icon }}{{ end }} "
        },
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:surface0",
          "foreground": "p:text",
          "template": "{{ .UserName }}@{{ .HostName }}"
        },
        {
          "type": "path",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:mauve",
          "foreground": "p:crust",
          "template": " {{ .Path }}",
          "options": {
            "folder_icon": " ",
            "home_icon": "~",
            "style": "agnoster_short",
            "max_depth": 3
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:peach{{ end }}"
          ],
          "foreground": "p:crust",
          "template": " {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }}*{{ end }}{{ if gt .Ahead 0 }} ↑{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ↓{{ .Behind }}{{ end }}",
          "options": {
            "branch_icon": " ",
            "cherry_pick_icon": " ",
            "commit_icon": " ",
            "fetch_status": true,
            "merge_icon": " ",
            "no_commits_icon": " ",
            "rebase_icon": " ",
            "revert_icon": " ",
            "tag_icon": "🏷 "
          }
        },
        {
          "type": "node",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:teal",
          "foreground": "p:crust",
          "template": " {{ .Full }}"
        },
        {
          "type": "python",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:yellow",
          "foreground": "p:crust",
          "template": " {{ .Full }}"
        },
        {
          "type": "rust",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:peach",
          "foreground": "p:crust",
          "template": " {{ .Full }}"
        },
        {
          "type": "go",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:sapphire",
          "foreground": "p:crust",
          "template": " {{ .Full }}"
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:surface1",
          "foreground": "p:yellow",
          "template": "󱎫 {{ .FormattedMs }}",
          "options": {
            "style": "austin",
            "threshold": 500
          }
        },
        {
          "type": "status",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:red",
          "foreground": "p:crust",
          "template": " {{ .Code }}",
          "options": {
            "always_enabled": false
          }
        },
        {
          "type": "root",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:maroon",
          "foreground": "p:crust",
          "template": "⚡ ROOT"
        }
      ]
    },
    {
      "alignment": "left",
      "type": "prompt",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:blue",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "└─❯ "
        }
      ]
    }
  ]
}
