{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "palette": {
    "base": "#eff1f5",
    "mantle": "#e6e9ef",
    "crust": "#dce0e8",
    "surface0": "#ccd0da",
    "surface1": "#bcc0cc",
    "surface2": "#acb0be",
    "text": "#4c4f69",
    "subtext0": "#6c6f85",
    "subtext1": "#5c5f77",
    "blue": "#1e66f5",
    "lavender": "#7287fd",
    "sapphire": "#209fb5",
    "sky": "#04a5e5",
    "teal": "#179299",
    "green": "#40a02b",
    "yellow": "#df8e1d",
    "peach": "#fe640b",
    "maroon": "#e64553",
    "red": "#d20f39",
    "mauve": "#8839ef",
    "pink": "#ea76cb",
    "flamingo": "#dd7878",
    "rosewater": "#dc8a78"
  },
  "blocks": [
    {
      "alignment": "left",
      "type": "prompt",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "background": "p:blue",
          "foreground": "p:base",
          "template": "{{ if .WSL }}WSL ({{ .OS }}){{ else }}{{ .Icon }}{{ end }} "
        },
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:surface0",
          "foreground": "p:text",
          "template": "{{ .UserName }}@{{ .HostName }}"
        },
        {
          "type": "path",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:mauve",
          "foreground": "p:base",
          "template": " {{ .Path }}",
          "options": {
            "folder_icon": " ",
            "home_icon": "~",
            "style": "agnoster_short",
            "max_depth": 3
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:peach{{ end }}"
          ],
          "foreground": "p:base",
          "template": " {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }}*{{ end }}{{ if gt .Ahead 0 }} ↑{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ↓{{ .Behind }}{{ end }}",
          "options": {
            "branch_icon": " ",
            "cherry_pick_icon": " ",
            "commit_icon": " ",
            "fetch_status": true,
            "merge_icon": " ",
            "no_commits_icon": " ",
            "rebase_icon": " ",
            "revert_icon": " ",
            "tag_icon": "🏷 "
          }
        },
        {
          "type": "node",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:teal",
          "foreground": "p:base",
          "template": " {{ .Full }}"
        },
        {
          "type": "python",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:yellow",
          "foreground": "p:base",
          "template": " {{ .Full }}"
        },
        {
          "type": "rust",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:peach",
          "foreground": "p:base",
          "template": " {{ .Full }}"
        },
        {
          "type": "go",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:sapphire",
          "foreground": "p:base",
          "template": " {{ .Full }}"
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:surface1",
          "foreground": "p:text",
          "template": "󱎫 {{ .FormattedMs }}",
          "options": {
            "style": "austin",
            "threshold": 500
          }
        },
        {
          "type": "status",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:red",
          "foreground": "p:base",
          "template": " {{ .Code }}",
          "options": {
            "always_enabled": false
          }
        },
        {
          "type": "root",
          "style": "diamond",
          "leading_diamond": " ",
          "trailing_diamond": "",
          "background": "p:maroon",
          "foreground": "p:base",
          "template": "⚡ ROOT"
        }
      ]
    },
    {
      "alignment": "left",
      "type": "prompt",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:blue",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "└─❯ "
        }
      ]
    }
  ]
}
